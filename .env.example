# Postgres 連線字串（從 Supabase 後台 → Project Settings → Database → Session pooler 複製）
# ⚠️ 一定要選「Session pooler」，不是 Direct connection 也不是 Transaction pooler
DATABASE_URI=postgresql://postgres.xxx:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# Payload 加密金鑰（隨意產一串長字串，建議 32+ 字元）
PAYLOAD_SECRET=replace-this-with-a-long-random-string

# 你的網站對外網址（部署後改成正式 URL）
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
